# Generate a strong secret key at: https://djecrety.ir
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production
DEBUG=False

# Your Railway domain (add after deployment)
ALLOWED_HOSTS=your-app.railway.app,localhost,127.0.0.1

# Your Vercel frontend URL (add after Vercel deployment)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Railway provides this automatically - do not change
# DATABASE_URL=postgresql://...

# M-PESA (fill in when ready)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-app.railway.app/api/payments/mpesa-callback/
